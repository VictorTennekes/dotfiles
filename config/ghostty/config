theme = catppuccin-mocha.conf
background-opacity = 0.95
cursor-style = block

# Force the block cursor: without this, zsh shell integration switches it to a
# beam in insert mode, which also breaks the cursor shaders below.
shell-integration-features = no-cursor

# Cursor trail shader (requires a block cursor, set above). Swap the filename
# to change the effect; options live in shaders/:
#   cursor_blaze · cursor_tail · cursor_sweep · cursor_warp · ripple_cursor · sonic_boom_cursor
# Paths are relative to this config file. animation=true renders only while
# focused (kinder on laptop battery than `always`).
custom-shader = shaders/cursor_tail.glsl
custom-shader-animation = true

window-padding-x = 5
window-padding-y = 5
window-padding-balance = true

font-family = JetBrainsMono Nerd
font-size = 13

copy-on-select = clipboard
shell-integration = zsh

# Kill desktop notifications entirely — copy-on-select would otherwise
# fire one per selection, and shells/programs sending OSC 9 / OSC 777
# turn into a constant nag.
desktop-notifications = false
app-notifications = no-clipboard-copy,no-config-reload
notify-on-command-finish-action = no-bell,no-notify

# macOS-only options (silently no-op on Linux, but Ghostty may warn at startup)
macos-option-as-alt = true
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
