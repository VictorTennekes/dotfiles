[alias]
	br = branch --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(contents:subject) %(color:green)(%(committerdate:relative)) [%(authorname)]' --sort=-committerdate
	ci = commit
	st = status
	cm = commit -m
	sw = switch
	swc = "!f() { \
        git show-ref --verify --quiet refs/heads/$1 && git switch $1 || git switch -c $1; \
    }; f"
	cb = "!f() { \
		git commit -m \"$(git branch --show-current): $1\"; \
	}; f"
	acm = !git add -u && git cm
	acb = !git add -u && git cb
	pob = !git push -u origin $(git branch --show-current)
	plob = !git pull origin $(git branch --show-current)
	rocket = "!f() { \
	   echo \"About to add, commit, and push with message: $1\"; \
	   printf 'Continue? [y/N] '; read ans; \
	   [ \"$ans\" = \"y\" ] || [ \"$ans\" = \"Y\" ] || { echo 'Aborted.'; return 1; }; \
	   git add . && git commit -m \"$1\" && git pob; \
	   }; f"
	last = log -1 HEAD
	unstage = reset HEAD --
	ll = log --oneline
	gl = config --global -l

[init]
    defaultBranch = main

[transfer]
    fsckobjects = true

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = true

[fetch]
    prune = true

[rebase]
    autoStash = true
    missingCommitsCheck = error

[rerere]
    enabled = true

[branch]
    sort = -committerdate

[column]
    ui = auto

[core]
	editor = nvim
	excludesfile = ~/.config/git/ignore
	pager = delta
	fsmonitor = true
	untrackedcache = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	features = catppuccin-mocha

[include]
	path = ./catppuccin.gitconfig

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[color]
	ui = auto

[commit]
	gpgsign = true

[gpg]
	format = ssh

[user]
	signingkey = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIH3q1jZWw7MRIxIf/GK5bo1+jL2HLXR+g3USNs/JJ0QK"

# Include local config
[include]
    path = ~/.gitconfig.local
