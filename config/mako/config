# mako — Niri rice. LAYOUT/STRUCTURE only.
# Colors live in the theme: theme-switch stamps them between the
# THEME:colors markers below (from config/theme/current/mako.conf).
# Switch themes with `theme-switch <name>`.

font=JetBrainsMono Nerd Font 11
width=340
height=120
margin=10
padding=14
border-size=2
border-radius=10
icons=1
max-icon-size=40
default-timeout=5000
ignore-timeout=0
anchor=top-right
layer=overlay
markup=1
actions=1

# THEME:colors:start
background-color=#1e1e2eee
text-color=#cdd6f4
border-color=#89b4fa
progress-color=over #313244
# THEME:colors:end

[urgency=low]
border-color=#6c7086

[urgency=high]
border-color=#f38ba8
default-timeout=0
