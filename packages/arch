#!/usr/bin/env bash
# Arch package manifest — Linux/Arch port of Brewfile/Packages.fedora.
# Sourced by scripts/install-arch.
#
# Native-first: pacman for official repos, paru for the AUR (the install
# script bootstraps/repairs paru if it's missing or ABI-broken). Work-only
# packages are gated by the hostname prefix `PC-` (same convention as the
# Brewfile). Override on this host with `IS_WORK=true make install`.

# `hostname` isn't installed on Arch by default; use $HOSTNAME / uname -n.
: "${IS_WORK:=$( [[ "${HOSTNAME:-$(uname -n)}" == PC-* ]] && echo true || echo false )}"

# ==============================================================================
# PACMAN — official repos (core/extra). All verified present.
# ==============================================================================
PACMAN_PACKAGES=(
  # shell + core CLI
  zsh
  bat
  eza
  fd               # fd-find on Fedora
  git-delta        # binary: delta
  fzf
  jq
  github-cli       # binary: gh
  glab
  git
  ripgrep
  stow
  tealdeer         # binary: tldr
  hyperfine
  procps-ng        # provides watch
  pacman-contrib   # paccache (weekly cache-trim timer), checkupdates
  fastfetch
  zoxide
  btop
  neovim
  vivid            # cargo on Fedora; native here
  tree-sitter-cli  # npm on Fedora; native here

  # prompt + version manager + TUIs (curl/copr on Fedora; native here)
  starship
  mise
  yazi
  lazygit

  # terminal
  ghostty

  # secrets desktop app (flatpak on Fedora; native here).
  # bitwarden-cli is installed via npm instead — see NPM_PACKAGES.
  bitwarden

  # toolchains / build deps (rust → paru + framework_tool; node → npm globals)
  base-devel
  rust             # system stable toolchain; install-arch swaps out rustup first
  npm              # node provider pulled transitively; see note below
  pkgconf

  # fonts + icons
  inter-font               # rsms-inter on Fedora — UI font
  ttf-jetbrains-mono-nerd  # terminal/editor Nerd Font
  papirus-icon-theme       # colorful app icons for the noctalia launcher

  # niri desktop / rice stack
  niri                     # scrollable-tiling Wayland compositor
                           # Shell: noctalia v5 — see `noctalia-git` in AUR below.
                           # It's a native Wayland/GLES shell (no Qt) that subsumes
                           # the bar, launcher, notifications, OSD, idle+lock, and
                           # wallpaper — replacing quickshell, waybar, mako, fuzzel,
                           # hyprlock, hypridle, awww and wlsunset that this stack
                           # used to carry as separate tools.
  pipewire pipewire-pulse wireplumber   # audio (wpctl)
  brightnessctl            # backlight/LED control (niri binds + noctalia OSD)
  pavucontrol              # audio mixer GUI
  wl-clipboard             # wl-copy / wl-paste
  xwayland-satellite       # X11 app support on niri (Steam and other X11-only apps)
  xdg-desktop-portal-gnome xdg-desktop-portal-gtk   # portals (screencast, dialogs)
  polkit-gnome             # polkit auth agent (spawned by niri — noctalia v5 does
                           # not bundle an auth agent, so this stays)
  gnome-keyring            # secrets + ssh keyring
  networkmanager           # wifi/networking (nmtui)

  # containers
  docker
  docker-compose

  # power management — adaptive on AC, scales down on battery (TLP).
  # NOTE: AC uses powersave governor + balance_performance EPP (NOT the
  # performance governor) — amd-pstate still boosts to max under load, but
  # idles cool instead of baking the chip during light use. See system/etc/tlp.d.
  tlp

  # system resilience & maintenance
  earlyoom         # kills the worst RAM hog before the kernel OOM freezes niri
  reflector        # refresh/sort pacman mirrors: reflector --country <X> --sort rate ...
  smartmontools    # SSD health: smartctl -a /dev/nvme0n1
)

# ==============================================================================
# AUR — installed via paru (bootstrapped by install-arch)
# ==============================================================================
AUR_PACKAGES=(
  noctalia-git             # Noctalia v5 — native Wayland/GLES desktop shell (bar,
                           # launcher, notifications, OSD, idle+lock, wallpaper).
                           # Launched via `spawn-at-startup "noctalia"` in niri.
                           # Pre-1.0/alpha: pin/rollback here if a build regresses.
  zen-browser-bin
  fw-fanctrl               # gentler EC fan curve for Framework 13; pulls fw-ectool.
                           # install-arch enables fw-fanctrl.service (default: lazy curve)
  git-machete              # git branch management
  proton-ge-custom         # Proton fork with better game compatibility (esp. Ubisoft titles)
)

# ==============================================================================
# GAMING — needs the [multilib] repo; install-arch enables it before installing
# ==============================================================================
GAMING_PACKAGES=(
  steam                  # Steam — Proton runs TMNF and other Windows games
  lib32-vulkan-radeon    # 32-bit Vulkan (TMNF is a 32-bit title)
  gamescope              # micro-compositor: clean fullscreen on Wayland tiling WMs
  gamemode lib32-gamemode
  mangohud lib32-mangohud
)

# ==============================================================================
# CARGO — tools with no reliable package (none needed on Arch currently)
# ==============================================================================
CARGO_PACKAGES=()

# ==============================================================================
# NPM — user-level global installs (prefix ~/.local to avoid sudo)
# ==============================================================================
NPM_PACKAGES=(
  "@google/gemini-cli"
  "@bitwarden/cli"          # provides `bw`; avoids nodejs-lts-jod conflict
  "repomix"
)

# ==============================================================================
# FLATPAK — none (native-first on Arch). Add app IDs here if ever needed.
# ==============================================================================
FLATPAK_PACKAGES=()

# ==============================================================================
# SHELL / CURL INSTALLERS — vendor scripts & git clones (must be idempotent)
# ==============================================================================
# Each entry: "name|shell-command". The command runs unconditionally; include
# your own existence check inside it.
SHELL_INSTALLERS=(
  'antidote|[ -d "$HOME/.local/share/antidote" ] || git clone --depth=1 https://github.com/mattmc3/antidote "$HOME/.local/share/antidote"'
  'ollama|command -v ollama >/dev/null || curl -fsSL https://ollama.com/install.sh | sh'
  'opencode|command -v opencode >/dev/null || curl -fsSL https://opencode.ai/install | bash'
  'claude|command -v claude >/dev/null || curl -fsSL https://claude.ai/install.sh | bash'
  'framework_tool|[ -x "$HOME/.cargo/bin/framework_tool" ] || cargo install --locked --git https://github.com/FrameworkComputer/framework-system framework_tool'
)

# ==============================================================================
# WORK-SPECIFIC — gated by IS_WORK (default: hostname starts with PC-)
# ==============================================================================
PACMAN_PACKAGES_WORK=(
  pre-commit
  parallel
  yq
  gnupg               # provides gpg
  pinentry
  kubectx             # provides kubectx + kubens
  helm
  python-pip
  python-pipx         # for dbt-core, etc. into isolated venvs
  ruff
  k9s
)
AUR_PACKAGES_WORK=(
  slack-desktop
)
FLATPAK_PACKAGES_WORK=()
SHELL_INSTALLERS_WORK=(
  'uv|command -v uv >/dev/null || curl -LsSf https://astral.sh/uv/install.sh | sh'
  'krew|command -v kubectl-krew >/dev/null || ( set -e; cd "$(mktemp -d)"; curl -fsSLO https://github.com/kubernetes-sigs/krew/releases/latest/download/krew-linux_amd64.tar.gz; tar zxvf krew-linux_amd64.tar.gz; ./krew-linux_amd64 install krew )'
)

# ==============================================================================
# MANUAL — packages not auto-installed (notes only)
# ==============================================================================
# - Niri + Waybar rice live in config/niri and config/waybar (stowed separately),
#   not in this package manifest. Compositor stack already installed on r2d2.
# - terraform: AUR `terraform` (or HashiCorp binary).
# - gcloud:    AUR `google-cloud-cli`.
# - dbt-core:  `pipx install dbt-core` after python-pipx.
# - WhiteSur icons / GNOME tweaks: dropped — niri desktop, not GNOME.
# - nodejs: intentionally NOT listed. bitwarden-cli depends on `nodejs-lts-jod`,
#   which conflicts with `nodejs`; listing both aborts the --noconfirm txn.
#   Let bitwarden-cli pull nodejs-lts-jod (it provides nodejs → satisfies npm).
