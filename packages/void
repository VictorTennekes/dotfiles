#!/usr/bin/env bash
# Void Linux package manifest (host: bb8). TEMPLATE — fill in / verify names.
# Sourced by scripts/install-void. Same array contract as Packages.arch.
#
# Void notes:
#  - Package manager is XBPS: `xbps-install -S <pkg>`, `xbps-query -Rs <name>`.
#  - Use the GLIBC edition of Void (not musl) — prebuilt binaries, Electron,
#    some cargo crates, and Steam need glibc.
#  - No AUR. Build extras with xbps-src, or use Flatpak.
#  - Services are runit (handled by install-void via the common enable_service).
#  - Verify every name with `xbps-query -Rs <name>` before first run.

: "${IS_WORK:=$( [[ "${HOSTNAME:-$(uname -n)}" == PC-* ]] && echo true || echo false )}"

# ==============================================================================
# XBPS — native repo packages
# ==============================================================================
XBPS_PACKAGES=(
  # shell + core CLI (names mostly match Arch; verify on Void)
  zsh bat eza fd fzf jq git ripgrep stow tealdeer hyperfine fastfetch
  zoxide btop neovim zig
  delta            # git-delta is `delta` on Void
  github-cli glab
  starship
  # toolchains / build deps
  base-devel rust nodejs npm pkg-config
  # fonts
  font-inter ttf-jetbrains-mono   # TODO: confirm Void font package names

  # TODO niri desktop stack on Void: niri waybar mako fuzzel swaybg swaylock
  #      swayidle pipewire wireplumber brightnessctl pavucontrol wl-clipboard
  #      xdg-desktop-portal-gtk polkit gnome-keyring NetworkManager wlsunset
  #      (verify availability; some may need xbps-src or flatpak)
  # TODO power: tlp  (runit service)
)
XBPS_PACKAGES_WORK=(
  # pre-commit parallel yq gnupg pinentry kubectx helm python3-pip ruff k9s
)

# ==============================================================================
# FLATPAK — GUI apps Void lacks natively (browsers, etc.)
# ==============================================================================
FLATPAK_PACKAGES=()
FLATPAK_PACKAGES_WORK=()

# ==============================================================================
# CARGO / NPM — user-level (identical across distros)
# ==============================================================================
CARGO_PACKAGES=()
NPM_PACKAGES=(
  "@google/gemini-cli"
  "@bitwarden/cli"
)

# ==============================================================================
# SHELL / CURL INSTALLERS — vendor scripts (identical across distros)
# ==============================================================================
SHELL_INSTALLERS=(
  'antidote|[ -d "$HOME/.local/share/antidote" ] || git clone --depth=1 https://github.com/mattmc3/antidote "$HOME/.local/share/antidote"'
  'opencode|command -v opencode >/dev/null || curl -fsSL https://opencode.ai/install | bash'
  'claude|command -v claude >/dev/null || curl -fsSL https://claude.ai/install.sh | bash'
)
SHELL_INSTALLERS_WORK=()

# ==============================================================================
# SERVICES — runit services to enable (install-void links into /var/service)
# ==============================================================================
RUNIT_SERVICES=(
  # NetworkManager
  # tlp
)
