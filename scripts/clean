#!/bin/bash
# Removes symlinks created by stow.

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT=$(dirname "$SCRIPT_DIR")
OS=$(uname -s)

STOW_FLAGS=()
if [[ "$OS" != "Darwin" ]]; then
  STOW_FLAGS+=(--ignore='^karabiner$')
fi

echo "🧹 Removing config symlinks..."
stow -d "$PROJECT_ROOT" -t "$HOME/.config" "${STOW_FLAGS[@]}" -D config

echo "🧹 Removing home symlinks..."
stow -d "$PROJECT_ROOT" -t "$HOME" -D home

echo "✅ Clean complete."
