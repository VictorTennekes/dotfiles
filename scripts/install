#!/bin/bash
# Symlinks dotfiles using GNU Stow. Cross-platform (macOS + Linux).

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT=$(dirname "$SCRIPT_DIR")
OS=$(uname -s)

# --- 0. Clone nvim config if not present ---
NVIM_CONFIG_DIR="$PROJECT_ROOT/config/nvim"

if [ ! -d "$NVIM_CONFIG_DIR" ] || [ -z "$(ls -A "$NVIM_CONFIG_DIR" 2>/dev/null)" ]; then
    echo "📦 'nvim' config not found — cloning from GitHub..."
    rmdir "$NVIM_CONFIG_DIR" 2>/dev/null || true
    git clone https://github.com/victortennekes/nvim "$NVIM_CONFIG_DIR" || {
        echo "❌ Failed to clone nvim config."
    }
else
    echo "✅ 'nvim' config already exists. Skipping clone."
fi

# --- 1. Link config/ → ~/.config/ via stow (cross-platform) ---
echo "🔗 Linking config directories to ~/.config..."
mkdir -p "$HOME/.config"
stow -d "$PROJECT_ROOT" -t "$HOME/.config" config

# --- 2. Link platform-specific configs ---
if [[ "$OS" == "Darwin" ]]; then
  echo "🔗 Linking macOS configs to ~/.config..."
  stow -d "$PROJECT_ROOT" -t "$HOME/.config" darwin
else
  echo "🔗 Linking Linux configs to ~/.config..."
  stow -d "$PROJECT_ROOT" -t "$HOME/.config" linux

  # Noctalia v5 reads its live config from ~/.local/state (not ~/.config), so
  # stow can't reach it — symlink settings.toml in directly. Noctalia writes
  # in place, so runtime tweaks flow back to the repo through the symlink.
  echo "🔗 Linking Noctalia settings.toml to ~/.local/state..."
  mkdir -p "$HOME/.local/state/noctalia"
  ln -sf "$PROJECT_ROOT/linux/noctalia/settings.toml" "$HOME/.local/state/noctalia/settings.toml"
fi

# --- 3. Link home/ → ~/ via stow ---
echo "🔗 Linking home files to ~..."
stow -d "$PROJECT_ROOT" -t "$HOME" home

echo "✅ Done."
