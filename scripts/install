#!/bin/bash
# Symlinks dotfiles using GNU Stow.

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT=$(dirname "$SCRIPT_DIR")

# --- 0. Clone nvim config if not present ---
NVIM_CONFIG_DIR="$PROJECT_ROOT/config/nvim"

if [ ! -d "$NVIM_CONFIG_DIR" ]; then
    echo "📦 'nvim' config not found — cloning from GitHub..."
    git clone https://github.com/victortennekes/nvim "$NVIM_CONFIG_DIR" || {
        echo "❌ Failed to clone nvim config."
    }
else
    echo "✅ 'nvim' config already exists. Skipping clone."
fi

# --- 1. Link config/ → ~/.config/ via stow ---
echo "🔗 Linking config directories to ~/.config..."
mkdir -p "$HOME/.config"
stow -d "$PROJECT_ROOT" -t "$HOME/.config" config

# --- 2. Link home/ → ~/ via stow ---
echo "🔗 Linking home files to ~..."
stow -d "$PROJECT_ROOT" -t "$HOME" home

echo "✅ Done."
