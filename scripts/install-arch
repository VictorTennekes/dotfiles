#!/usr/bin/env bash
# Install Arch packages from Packages.arch.
#
# Usage:    scripts/install-arch
# Env:      IS_WORK=true  forces installation of work-only packages
#
# Native-first: pacman for repos, paru for the AUR. Requires sudo for pacman.

set -uo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT=$(dirname "$SCRIPT_DIR")
MANIFEST="$PROJECT_ROOT/Packages.arch"

if [[ ! -f "$MANIFEST" ]]; then
  echo "❌ Packages.arch not found at $MANIFEST" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$MANIFEST"

step()  { printf '\n\033[1;34m==>\033[0m \033[1m%s\033[0m\n' "$*"; }
say()   { printf '    %s\n' "$*"; }
warn()  { printf '\033[1;33m    ! %s\033[0m\n' "$*"; }

# Prime sudo up front and keep the credential warm for the whole run. The AUR
# compile (paru) takes minutes; without this the sudo timestamp expires and the
# `pacman -U` that follows times out waiting for a password ("sudo: timed out
# reading password"), aborting the paru install.
step "Sudo (cached for the whole run)"
sudo -v || { warn "sudo is required for package installation"; exit 1; }
( while kill -0 "$$" 2>/dev/null; do sudo -n true 2>/dev/null; sleep 50; done ) &
SUDO_KEEPALIVE_PID=$!
trap 'kill "$SUDO_KEEPALIVE_PID" 2>/dev/null' EXIT

run_installers() {
  local entry name cmd
  for entry in "$@"; do
    name="${entry%%|*}"
    cmd="${entry#*|}"
    say "→ $name"
    bash -c "$cmd" || warn "$name failed (continuing)"
  done
}

# --- 0. Resolve known one-way conflicts --------------------------------------
# This manifest standardizes on the `rust` package. If rustup is installed it
# conflicts (both provide cargo) and --noconfirm won't auto-replace it, so drop
# rustup first. Cargo-built binaries in ~/.cargo/bin are unaffected.
if pacman -Qq rust >/dev/null 2>&1; then :; elif pacman -Qq rustup >/dev/null 2>&1; then
  step "Swapping rustup → rust"
  sudo pacman -Rdd --noconfirm rustup
fi

# --- 1. Pacman ----------------------------------------------------------------
step "Pacman packages"
if ! sudo pacman -Syu --needed --noconfirm "${PACMAN_PACKAGES[@]}"; then
  warn "pacman transaction failed — NOTHING from the repo set was installed."
  warn "Resolve the conflict reported above, then re-run; later steps (stow,"
  warn "AUR) depend on these packages and will fail until this succeeds."
fi

if [[ "$IS_WORK" == "true" && ${#PACMAN_PACKAGES_WORK[@]} -gt 0 ]]; then
  step "Pacman (work)"
  sudo pacman -S --needed --noconfirm "${PACMAN_PACKAGES_WORK[@]}"
fi

# --- 1b. Gaming (needs the multilib repo) ------------------------------------
if [[ ${#GAMING_PACKAGES[@]} -gt 0 ]]; then
  step "Gaming packages (multilib)"
  # Enable [multilib] if it's still commented out (Steam + lib32 libs need it).
  if ! pacman-conf --repo-list 2>/dev/null | grep -qx multilib; then
    say "enabling [multilib] in /etc/pacman.conf"
    sudo sed -i '/^#\[multilib\]/,/^#Include/ s/^#//' /etc/pacman.conf
    sudo pacman -Sy
  fi
  sudo pacman -S --needed --noconfirm "${GAMING_PACKAGES[@]}" || warn "some gaming packages failed"
fi

# --- 2. AUR helper (paru) — bootstrap or repair -------------------------------
# paru-bin can break across pacman libalpm bumps (libalpm.so.NN not found).
# Build paru from source so it links the currently installed libalpm.
ensure_paru() {
  if command -v paru >/dev/null 2>&1 && paru --version >/dev/null 2>&1; then
    return 0
  fi
  step "Bootstrapping paru (AUR helper)"
  say "paru missing or broken — building from source against current pacman"
  # A broken paru-bin would conflict with the source build; makepkg -si
  # --noconfirm refuses conflicts, so drop it first (-Rdd: ignore deps).
  if pacman -Qq paru-bin >/dev/null 2>&1; then
    say "removing conflicting paru-bin"
    sudo pacman -Rdd --noconfirm paru-bin paru-bin-debug 2>/dev/null \
      || sudo pacman -Rdd --noconfirm paru-bin
  fi
  local tmp
  tmp=$(mktemp -d)
  if git clone --depth=1 https://aur.archlinux.org/paru.git "$tmp" \
     && ( cd "$tmp" && makepkg -si --noconfirm ); then
    rm -rf "$tmp"
    return 0
  fi
  rm -rf "$tmp"
  warn "paru bootstrap failed — install an AUR helper manually, then re-run"
  return 1
}

# --- 3. AUR packages ----------------------------------------------------------
if [[ ${#AUR_PACKAGES[@]} -gt 0 ]] || { [[ "$IS_WORK" == "true" ]] && [[ ${#AUR_PACKAGES_WORK[@]} -gt 0 ]]; }; then
  if ensure_paru; then
    [[ ${#AUR_PACKAGES[@]} -gt 0 ]] && { step "AUR packages"; paru -S --needed --noconfirm "${AUR_PACKAGES[@]}" || warn "some AUR packages failed"; }
    if [[ "$IS_WORK" == "true" && ${#AUR_PACKAGES_WORK[@]} -gt 0 ]]; then
      step "AUR (work)"
      paru -S --needed --noconfirm "${AUR_PACKAGES_WORK[@]}" || warn "some work AUR packages failed"
    fi
  fi
fi

# --- 4. Flatpak (only if any are listed) --------------------------------------
if [[ ${#FLATPAK_PACKAGES[@]} -gt 0 ]] || { [[ "$IS_WORK" == "true" ]] && [[ ${#FLATPAK_PACKAGES_WORK[@]} -gt 0 ]]; }; then
  command -v flatpak >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm flatpak
  flatpak remote-add --if-not-exists --user flathub https://flathub.org/repo/flathub.flatpakrepo
  [[ ${#FLATPAK_PACKAGES[@]} -gt 0 ]] && { step "Flatpak apps"; flatpak install --user -y --noninteractive flathub "${FLATPAK_PACKAGES[@]}" || warn "some flatpaks failed"; }
  if [[ "$IS_WORK" == "true" && ${#FLATPAK_PACKAGES_WORK[@]} -gt 0 ]]; then
    step "Flatpak (work)"
    flatpak install --user -y --noninteractive flathub "${FLATPAK_PACKAGES_WORK[@]}" || true
  fi
fi

# --- 5. Cargo -----------------------------------------------------------------
if [[ ${#CARGO_PACKAGES[@]} -gt 0 ]]; then
  step "Cargo packages"
  for pkg in "${CARGO_PACKAGES[@]}"; do
    if cargo install --list | grep -q "^${pkg} "; then
      say "$pkg already installed; skipping"
    else
      cargo install --locked "$pkg" || warn "$pkg failed"
    fi
  done
fi

# --- 6. NPM (user-level prefix to avoid sudo) ---------------------------------
if [[ ${#NPM_PACKAGES[@]} -gt 0 ]]; then
  step "NPM packages (user-level prefix)"
  mkdir -p "$HOME/.local"
  npm config set prefix "$HOME/.local" >/dev/null
  for pkg in "${NPM_PACKAGES[@]}"; do
    say "→ $pkg"
    npm install -g "$pkg" || warn "$pkg failed"
  done
fi

# --- 7. Shell installers ------------------------------------------------------
if [[ ${#SHELL_INSTALLERS[@]} -gt 0 ]]; then
  step "Shell installers"
  run_installers "${SHELL_INSTALLERS[@]}"
fi

if [[ "$IS_WORK" == "true" && ${#SHELL_INSTALLERS_WORK[@]} -gt 0 ]]; then
  step "Shell installers (work)"
  run_installers "${SHELL_INSTALLERS_WORK[@]}"
fi

# --- 8. System overrides (libinput trackpad quirk, etc.) ----------------------
# Sync each file under system/ into / via sudo, idempotent (only writes when
# content differs). Keeps trackpad/scroll quirks tracked in the dotfiles.
SYSTEM_DIR="$PROJECT_ROOT/system"
if [[ -d "$SYSTEM_DIR" ]]; then
  step "System overrides (sudo)"
  while IFS= read -r -d '' src; do
    rel="${src#"$SYSTEM_DIR"/}"
    dst="/$rel"
    if ! sudo cmp -s "$src" "$dst" 2>/dev/null; then
      say "→ $dst"
      sudo install -Dm644 "$src" "$dst"
    else
      say "= $dst (already current)"
    fi
  done < <(find "$SYSTEM_DIR" -type f -print0)
fi

# --- 9. Default shell ---------------------------------------------------------
if [[ "$SHELL" != *zsh ]] && command -v zsh >/dev/null 2>&1; then
  step "Default shell"
  say "setting login shell to zsh (may prompt for password)"
  chsh -s "$(command -v zsh)" || warn "chsh failed — set zsh as login shell manually"
fi

step "Arch packages installed."
