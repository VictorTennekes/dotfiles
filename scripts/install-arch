#!/usr/bin/env bash
# Install Arch packages from packages/arch.
#
# Usage:    scripts/install-arch
# Env:      IS_WORK=true  forces installation of work-only packages
#
# Native-first: pacman for repos, paru for the AUR. Requires sudo.
# Shared, distro-agnostic steps live in scripts/lib/common.sh.

set -uo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT=$(dirname "$SCRIPT_DIR")

# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"
load_manifest "$PROJECT_ROOT/packages/arch"

prime_sudo

# --- Resolve known one-way conflicts -----------------------------------------
# This manifest standardizes on the `rust` package. If rustup is installed it
# conflicts (both provide cargo) and --noconfirm won't auto-replace it.
if pacman -Qq rust >/dev/null 2>&1; then :; elif pacman -Qq rustup >/dev/null 2>&1; then
  step "Swapping rustup → rust"
  sudo pacman -Rdd --noconfirm rustup
fi

# --- Pacman (repo packages) --------------------------------------------------
step "Pacman packages"
if ! sudo pacman -Syu --needed --noconfirm "${PACMAN_PACKAGES[@]}"; then
  warn "pacman transaction failed — NOTHING from the repo set was installed."
  warn "Resolve the conflict reported above, then re-run; later steps (stow,"
  warn "AUR) depend on these packages and will fail until this succeeds."
fi

if [[ "$IS_WORK" == "true" && ${#PACMAN_PACKAGES_WORK[@]} -gt 0 ]]; then
  step "Pacman (work)"
  sudo pacman -S --needed --noconfirm "${PACMAN_PACKAGES_WORK[@]}"
fi

# --- Gaming (needs the multilib repo) ----------------------------------------
if [[ ${#GAMING_PACKAGES[@]} -gt 0 ]]; then
  step "Gaming packages (multilib)"
  if ! pacman-conf --repo-list 2>/dev/null | grep -qx multilib; then
    say "enabling [multilib] in /etc/pacman.conf"
    sudo sed -i '/^#\[multilib\]/,/^#Include/ s/^#//' /etc/pacman.conf
    sudo pacman -Sy
  fi
  sudo pacman -S --needed --noconfirm "${GAMING_PACKAGES[@]}" || warn "some gaming packages failed"
fi

# --- AUR helper (paru) — bootstrap or repair ---------------------------------
# paru-bin can break across pacman libalpm bumps (libalpm.so.NN not found);
# build paru from source so it links the currently installed libalpm.
ensure_paru() {
  if command -v paru >/dev/null 2>&1 && paru --version >/dev/null 2>&1; then
    return 0
  fi
  step "Bootstrapping paru (AUR helper)"
  say "paru missing or broken — building from source against current pacman"
  if pacman -Qq paru-bin >/dev/null 2>&1; then
    say "removing conflicting paru-bin"
    sudo pacman -Rdd --noconfirm paru-bin paru-bin-debug 2>/dev/null \
      || sudo pacman -Rdd --noconfirm paru-bin
  fi
  local tmp
  tmp=$(mktemp -d)
  if git clone --depth=1 https://aur.archlinux.org/paru.git "$tmp" \
     && ( cd "$tmp" && makepkg -si --noconfirm ); then
    rm -rf "$tmp"; return 0
  fi
  rm -rf "$tmp"
  warn "paru bootstrap failed — install an AUR helper manually, then re-run"
  return 1
}

if [[ ${#AUR_PACKAGES[@]} -gt 0 ]] || { [[ "$IS_WORK" == "true" ]] && [[ ${#AUR_PACKAGES_WORK[@]} -gt 0 ]]; }; then
  if ensure_paru; then
    [[ ${#AUR_PACKAGES[@]} -gt 0 ]] && { step "AUR packages"; paru -S --needed --noconfirm "${AUR_PACKAGES[@]}" || warn "some AUR packages failed"; }
    if [[ "$IS_WORK" == "true" && ${#AUR_PACKAGES_WORK[@]} -gt 0 ]]; then
      step "AUR (work)"
      paru -S --needed --noconfirm "${AUR_PACKAGES_WORK[@]}" || warn "some work AUR packages failed"
    fi
  fi
fi

# --- Shared steps (flatpak / cargo / npm / installers / system overrides) ----
install_flatpaks
install_cargo
install_npm
install_shell_installers
sync_system_overrides

# --- Boot tuning (apply synced GRUB defaults + trim rEFInd) -------------------
# sync_system_overrides copied system/etc/default/grub above; regenerate Arch's
# grub.cfg so TIMEOUT=0/hidden/console take effect (Fedora's cfg on the ESP is
# untouched).
if pacman -Qq grub >/dev/null 2>&1 && [[ -d /boot/grub ]]; then
  step "Regenerating GRUB config"
  sudo grub-mkconfig -o /boot/grub/grub.cfg || warn "grub-mkconfig failed"
fi
# rEFInd fronts the multiboot menu; drop its timeout to 1s (idempotent — only if
# currently >2). Its config lives on the ESP, not /etc, so it isn't file-synced.
REFIND_CONF=/efi/EFI/refind/refind.conf
if sudo test -f "$REFIND_CONF" 2>/dev/null; then
  refind_to=$(sudo grep -E '^[[:space:]]*timeout' "$REFIND_CONF" | grep -oE '[0-9]+' | head -1)
  if [[ -n "${refind_to:-}" && "$refind_to" -gt 2 ]]; then
    step "Lowering rEFInd timeout ${refind_to} → 1"
    sudo sed -i -E 's/^([[:space:]]*timeout[[:space:]]+).*/\11/' "$REFIND_CONF"
  fi
fi

# --- Services (systemd) ------------------------------------------------------
if pacman -Qq tlp >/dev/null 2>&1; then
  step "Power management (TLP)"
  enable_service tlp
  sudo systemctl mask systemd-rfkill.service systemd-rfkill.socket 2>/dev/null || true
fi
if pacman -Qq fw-fanctrl >/dev/null 2>&1; then
  step "Fan control (fw-fanctrl)"
  enable_service fw-fanctrl          # gentler EC fan curve (default strategy: lazy)
fi
if pacman -Qq pacman-contrib >/dev/null 2>&1; then
  step "Package-cache trim (paccache.timer)"   # weekly: keep last 3 versions
  sudo systemctl enable --now paccache.timer 2>/dev/null \
    || warn "could not enable paccache.timer"
fi
if command -v systemctl >/dev/null 2>&1; then
  step "Weekly SSD TRIM (fstrim.timer)"
  sudo systemctl enable --now fstrim.timer 2>/dev/null || warn "could not enable fstrim.timer"
fi
pacman -Qq earlyoom >/dev/null 2>&1 && enable_service earlyoom   # OOM protection for the desktop
pacman -Qq networkmanager >/dev/null 2>&1 && enable_service NetworkManager
pacman -Qq docker >/dev/null 2>&1 && { enable_service docker; sudo usermod -aG docker "$USER"; }

ensure_default_shell

step "Arch packages installed."
