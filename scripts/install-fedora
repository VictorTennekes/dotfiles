#!/usr/bin/env bash
# Install Fedora packages from Packages.fedora.
#
# Usage:    scripts/install-fedora
# Env:      IS_WORK=true  forces installation of work-only packages
#
# Requires sudo for dnf operations.

set -uo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT=$(dirname "$SCRIPT_DIR")
MANIFEST="$PROJECT_ROOT/Packages.fedora"

if [[ ! -f "$MANIFEST" ]]; then
  echo "❌ Packages.fedora not found at $MANIFEST" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$MANIFEST"

step()  { printf '\n\033[1;34m==>\033[0m \033[1m%s\033[0m\n' "$*"; }
say()   { printf '    %s\n' "$*"; }
warn()  { printf '\033[1;33m    ! %s\033[0m\n' "$*"; }

run_installers() {
  local entry name cmd
  for entry in "$@"; do
    name="${entry%%|*}"
    cmd="${entry#*|}"
    say "→ $name"
    bash -c "$cmd" || warn "$name failed (continuing)"
  done
}

# --- 1. DNF -------------------------------------------------------------------
step "DNF packages"
sudo dnf install -y --skip-unavailable "${DNF_PACKAGES[@]}"

if [[ "$IS_WORK" == "true" && ${#DNF_PACKAGES_WORK[@]} -gt 0 ]]; then
  step "DNF (work)"
  sudo dnf install -y --skip-unavailable "${DNF_PACKAGES_WORK[@]}"
fi

# --- 2. COPR ------------------------------------------------------------------
if [[ ${#COPR_REPOS[@]} -gt 0 ]]; then
  step "COPR repos"
  for repo in "${COPR_REPOS[@]}"; do
    say "enable $repo"
    sudo dnf copr enable -y "$repo"
  done
  sudo dnf install -y "${COPR_PACKAGES[@]}"
fi

if [[ "$IS_WORK" == "true" && ${#COPR_REPOS_WORK[@]} -gt 0 ]]; then
  step "COPR (work)"
  for repo in "${COPR_REPOS_WORK[@]}"; do
    sudo dnf copr enable -y "$repo"
  done
  [[ ${#COPR_PACKAGES_WORK[@]} -gt 0 ]] && sudo dnf install -y "${COPR_PACKAGES_WORK[@]}"
fi

# --- 3. Flatpak ---------------------------------------------------------------
if ! command -v flatpak >/dev/null 2>&1; then
  step "Installing flatpak"
  sudo dnf install -y flatpak
fi

step "Flathub remote"
flatpak remote-add --if-not-exists --user flathub https://flathub.org/repo/flathub.flatpakrepo

if [[ ${#FLATPAK_PACKAGES[@]} -gt 0 ]]; then
  step "Flatpak apps"
  flatpak install --user -y --noninteractive flathub "${FLATPAK_PACKAGES[@]}" \
    || warn "some flatpaks may not exist on flathub yet — review output above"
fi

if [[ "$IS_WORK" == "true" && ${#FLATPAK_PACKAGES_WORK[@]} -gt 0 ]]; then
  step "Flatpak (work)"
  flatpak install --user -y --noninteractive flathub "${FLATPAK_PACKAGES_WORK[@]}" || true
fi

# --- 4. Cargo -----------------------------------------------------------------
if [[ ${#CARGO_PACKAGES[@]} -gt 0 ]]; then
  step "Cargo packages"
  for pkg in "${CARGO_PACKAGES[@]}"; do
    if cargo install --list | grep -q "^${pkg} "; then
      say "$pkg already installed; skipping"
    else
      cargo install --locked "$pkg" || warn "$pkg failed"
    fi
  done
fi

# --- 5. NPM (user-level prefix to avoid sudo) ---------------------------------
if [[ ${#NPM_PACKAGES[@]} -gt 0 ]]; then
  step "NPM packages (user-level prefix)"
  mkdir -p "$HOME/.local"
  npm config set prefix "$HOME/.local" >/dev/null
  for pkg in "${NPM_PACKAGES[@]}"; do
    say "→ $pkg"
    npm install -g "$pkg" || warn "$pkg failed"
  done
fi

# --- 6. Shell installers ------------------------------------------------------
if [[ ${#SHELL_INSTALLERS[@]} -gt 0 ]]; then
  step "Shell installers"
  run_installers "${SHELL_INSTALLERS[@]}"
fi

if [[ "$IS_WORK" == "true" && ${#SHELL_INSTALLERS_WORK[@]} -gt 0 ]]; then
  step "Shell installers (work)"
  run_installers "${SHELL_INSTALLERS_WORK[@]}"
fi

# --- 7. GNOME settings (Mac-style keybindings + custom launcher hotkeys) ------
if [[ "${XDG_CURRENT_DESKTOP:-}" == *GNOME* ]] && command -v gsettings >/dev/null 2>&1; then
  step "GNOME settings"

  # Mac-style window keybindings
  gsettings set org.gnome.desktop.wm.keybindings close      "['<Super>q']"
  gsettings set org.gnome.desktop.wm.keybindings minimize   "['<Super>h', '<Super>m']"

  # Custom keybindings: Super+Space → Vicinae, Super+Return → Ghostty
  cb_root="org.gnome.settings-daemon.plugins.media-keys"
  cb_path_root="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings"
  declare -a desired_paths=(
    "$cb_path_root/vicinae/"
    "$cb_path_root/ghostty/"
  )
  gsettings set "$cb_root" custom-keybindings \
    "['${desired_paths[0]}', '${desired_paths[1]}']"

  gsettings set "$cb_root.custom-keybinding:${desired_paths[0]}" name    'Vicinae'
  gsettings set "$cb_root.custom-keybinding:${desired_paths[0]}" command 'vicinae toggle'
  gsettings set "$cb_root.custom-keybinding:${desired_paths[0]}" binding '<Super>space'

  gsettings set "$cb_root.custom-keybinding:${desired_paths[1]}" name    'Ghostty'
  gsettings set "$cb_root.custom-keybinding:${desired_paths[1]}" command 'ghostty'
  gsettings set "$cb_root.custom-keybinding:${desired_paths[1]}" binding '<Super>Return'

  # Inter as the system UI font (only if installed)
  if fc-list | grep -q "Inter:"; then
    gsettings set org.gnome.desktop.interface font-name          'Inter 11'
    gsettings set org.gnome.desktop.interface document-font-name 'Inter 11'
  fi

  # WhiteSur (macOS-style) icon theme — only if installed
  if [[ -d "$HOME/.local/share/icons/WhiteSur-dark" ]]; then
    gsettings set org.gnome.desktop.interface icon-theme 'WhiteSur-dark'
  fi

  # AppIndicator extension — required for Bitwarden/Slack/etc. tray icons.
  # The dnf package installs the files; we still need to enable it once.
  if gnome-extensions info appindicatorsupport@rgcjonas.gmail.com >/dev/null 2>&1; then
    gnome-extensions enable appindicatorsupport@rgcjonas.gmail.com 2>/dev/null || true
  fi

  say "GNOME keybindings + font + icons set."
fi

step "Fedora packages installed."
