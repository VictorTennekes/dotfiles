#!/usr/bin/env bash
# Install Fedora packages from packages/fedora.
#
# Usage:    scripts/install-fedora
# Env:      IS_WORK=true  forces installation of work-only packages
#
# Requires sudo for dnf. Shared, distro-agnostic steps live in
# scripts/lib/common.sh.

set -uo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT=$(dirname "$SCRIPT_DIR")

# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"
load_manifest "$PROJECT_ROOT/packages/fedora"

prime_sudo

# --- DNF (repo packages) -----------------------------------------------------
step "DNF packages"
sudo dnf install -y --skip-unavailable "${DNF_PACKAGES[@]}"

if [[ "$IS_WORK" == "true" && ${#DNF_PACKAGES_WORK[@]} -gt 0 ]]; then
  step "DNF (work)"
  sudo dnf install -y --skip-unavailable "${DNF_PACKAGES_WORK[@]}"
fi

# --- COPR --------------------------------------------------------------------
if [[ ${#COPR_REPOS[@]} -gt 0 ]]; then
  step "COPR repos"
  for repo in "${COPR_REPOS[@]}"; do
    say "enable $repo"
    sudo dnf copr enable -y "$repo"
  done
  sudo dnf install -y "${COPR_PACKAGES[@]}"
fi

if [[ "$IS_WORK" == "true" && ${#COPR_REPOS_WORK[@]} -gt 0 ]]; then
  step "COPR (work)"
  for repo in "${COPR_REPOS_WORK[@]}"; do
    sudo dnf copr enable -y "$repo"
  done
  [[ ${#COPR_PACKAGES_WORK[@]} -gt 0 ]] && sudo dnf install -y "${COPR_PACKAGES_WORK[@]}"
fi

# --- Shared steps ------------------------------------------------------------
command -v flatpak >/dev/null 2>&1 || { step "Installing flatpak"; sudo dnf install -y flatpak; }
install_flatpaks
install_cargo
install_npm
install_shell_installers
sync_system_overrides

# --- GNOME settings (Mac-style keybindings + custom launcher hotkeys) --------
if [[ "${XDG_CURRENT_DESKTOP:-}" == *GNOME* ]] && command -v gsettings >/dev/null 2>&1; then
  step "GNOME settings"

  # Mac-style window keybindings
  gsettings set org.gnome.desktop.wm.keybindings close      "['<Super>q']"
  gsettings set org.gnome.desktop.wm.keybindings minimize   "['<Super>h', '<Super>m']"

  # Custom keybindings: Super+Space → Vicinae, Super+Return → Ghostty.
  cb_root="org.gnome.settings-daemon.plugins.media-keys"
  cb_path_root="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings"
  dconf reset -f "$cb_path_root/" 2>/dev/null || true
  gsettings set "$cb_root" custom-keybindings \
    "['$cb_path_root/custom0/', '$cb_path_root/custom1/']"

  gsettings set "$cb_root.custom-keybinding:$cb_path_root/custom0/" name    'Vicinae'
  gsettings set "$cb_root.custom-keybinding:$cb_path_root/custom0/" command 'vicinae toggle'
  gsettings set "$cb_root.custom-keybinding:$cb_path_root/custom0/" binding '<Super>space'

  gsettings set "$cb_root.custom-keybinding:$cb_path_root/custom1/" name    'Ghostty'
  gsettings set "$cb_root.custom-keybinding:$cb_path_root/custom1/" command 'ghostty'
  gsettings set "$cb_root.custom-keybinding:$cb_path_root/custom1/" binding '<Super>Return'

  # Inter as the system UI font (only if installed)
  if fc-list | grep -q "Inter:"; then
    gsettings set org.gnome.desktop.interface font-name          'Inter 11'
    gsettings set org.gnome.desktop.interface document-font-name 'Inter 11'
  fi

  # WhiteSur (macOS-style) icon theme — only if installed
  if [[ -d "$HOME/.local/share/icons/WhiteSur-dark" ]]; then
    gsettings set org.gnome.desktop.interface icon-theme 'WhiteSur-dark'
  fi

  # AppIndicator extension — required for Bitwarden/Slack/etc. tray icons.
  if gnome-extensions info appindicatorsupport@rgcjonas.gmail.com >/dev/null 2>&1; then
    gnome-extensions enable appindicatorsupport@rgcjonas.gmail.com 2>/dev/null || true
  fi

  # Mutter experimental: variable refresh rate (ignored harmlessly if unsupported).
  current_exp=$(gsettings get org.gnome.mutter experimental-features)
  if [[ "$current_exp" != *variable-refresh-rate* ]]; then
    gsettings set org.gnome.mutter experimental-features \
      "['scale-monitor-framebuffer', 'xwayland-native-scaling', 'variable-refresh-rate']"
  fi

  # Per-app notification policy: silence ghostty.
  gsettings set org.gnome.desktop.notifications.application:/org/gnome/desktop/notifications/application/com-mitchellh-ghostty/ enable false

  # Dash-to-Dock tweaks (only if installed via Extension Manager)
  D2D_SCHEMAS="$HOME/.local/share/gnome-shell/extensions/dash-to-dock@micxgx.gmail.com/schemas"
  if [[ -d "$D2D_SCHEMAS" ]]; then
    GSETTINGS_SCHEMA_DIR="$D2D_SCHEMAS" gsettings set org.gnome.shell.extensions.dash-to-dock show-show-apps-button false
    GSETTINGS_SCHEMA_DIR="$D2D_SCHEMAS" gsettings set org.gnome.shell.extensions.dash-to-dock show-icons-notifications-counter true
    GSETTINGS_SCHEMA_DIR="$D2D_SCHEMAS" gsettings set org.gnome.shell.extensions.dash-to-dock show-icons-emblems true
    GSETTINGS_SCHEMA_DIR="$D2D_SCHEMAS" gsettings set org.gnome.shell.extensions.dash-to-dock application-counter-overrides-notifications false
  fi

  # blur-my-shell tweaks
  BMS_SCHEMAS="$HOME/.local/share/gnome-shell/extensions/blur-my-shell@aunetx/schemas"
  if [[ -d "$BMS_SCHEMAS" ]]; then
    GSETTINGS_SCHEMA_DIR="$BMS_SCHEMAS" gsettings set org.gnome.shell.extensions.blur-my-shell.lockscreen blur false
    GSETTINGS_SCHEMA_DIR="$BMS_SCHEMAS" gsettings set org.gnome.shell.extensions.blur-my-shell.overview style-components 0
  fi

  say "GNOME settings applied."
fi

step "Fedora packages installed."
