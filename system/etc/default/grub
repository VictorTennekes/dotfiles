# GRUB defaults for r2d2 (Arch). Synced to /etc/default/grub by install-arch,
# which then runs grub-mkconfig to regenerate Arch's /boot/grub/grub.cfg.
#
# Boot chain is firmware → rEFInd (the multiboot OS chooser, 1s timeout) → GRUB
# → kernel. GRUB is therefore a redundant second menu, so it is hidden and
# instant (TIMEOUT=0, STYLE=hidden); hold Esc/Shift at the GRUB stage to reveal
# it (e.g. to pick an alternate kernel). TERMINAL_OUTPUT=console skips GRUB's
# slow graphics-mode probe. zswap.enabled=0 because zram supersedes the dead zswap.
GRUB_DEFAULT=0
GRUB_TIMEOUT=0
GRUB_DISTRIBUTOR="Arch"
GRUB_CMDLINE_LINUX_DEFAULT="loglevel=3 quiet zswap.enabled=0"
GRUB_CMDLINE_LINUX=""
GRUB_PRELOAD_MODULES="part_gpt part_msdos lvm"
GRUB_TIMEOUT_STYLE=hidden
GRUB_TERMINAL_INPUT=console
GRUB_TERMINAL_OUTPUT=console
GRUB_GFXMODE=auto
GRUB_GFXPAYLOAD_LINUX=keep
GRUB_DISABLE_RECOVERY=true
